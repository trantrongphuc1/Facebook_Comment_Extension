{
  "manifest_version": 3,
  "name": "PhucTran auto comment",
  "version": "1.0",
  "description": "Tiện ích điền bình luận bán tự động cho bài viết Facebook",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "https://catbox.moe/*",
    "https://0x0.st/*",
    "https://tmpfiles.org/*",
    "https://transfer.sh/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhucTran auto comment"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}